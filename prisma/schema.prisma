generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phone       String?
  office      String
  startDate   String?
  status      String    @default("New")
  contactedAt DateTime?
  confirmedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
}
